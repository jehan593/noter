<?xml version="1.0" encoding="utf-8"?>
<!-- Gives the widget title row a distinct "button" look (vs. the plain background behind it) so
     it visually reads as the reliable, dedicated tap-to-open target — the ListView-backed content
     area below it can't offer the same one-tap guarantee since it also has to handle scrolling.
     API 31+ gets its own copy (drawable-v31) using the system's inner-radius dimension instead of
     this hardcoded 8dp, since those launchers auto-round the whole widget and a mismatched radius
     here looked inconsistent next to that outer curve. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/nord1" />
    <corners android:radius="8dp" />
</shape>
